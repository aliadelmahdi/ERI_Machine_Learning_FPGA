        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/CVS": true,
        "**/wlf*": true,
        "**/work": true,
        "**/*.mpf": true,
        "**/*.cr.mti": true,
